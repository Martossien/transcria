# Variables du déploiement Docker (générées automatiquement par scripts/docker_quickstart.sh).
# Copier en `.env.docker` et compléter, ou laisser le quickstart le générer.

# Mot de passe du rôle PostgreSQL `transcria` (service `db` du compose). OBLIGATOIRE.
POSTGRES_PASSWORD=

# Cache Hugging Face de l'hôte, monté dans le conteneur (évite de re-télécharger les modèles).
HF_CACHE_DIR=~/.cache/huggingface

# Token Hugging Face — requis UNIQUEMENT pour les modèles gated (Cohere STT, pyannote).
# Laisser vide pour un test avec le backend whisper (non gated). Accepter au préalable les
# conditions du modèle sur huggingface.co.
HF_TOKEN=
