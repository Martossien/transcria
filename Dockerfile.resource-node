# syntax=docker/dockerfile:1
#
# Image NŒUD DE RESSOURCES GPU — diarisation (pyannote) + STT (Cohere via vLLM).
# Cf. docs/PLAN_TEST_SPLIT_VLLM.md et docs/SERVICE_RESSOURCES_GPU.md.
#
# OBJECTIF DE TEST (cf. plan §0) : on installe **comme un utilisateur**, en lançant
# `install.sh --profile resource-node --inference-service` AU BUILD. Le build qui passe
# = preuve que ce chemin d'install (jamais couvert jusqu'ici) fonctionne ; tout échec est
# un *finding* à corriger dans le code/install, pas à contourner. P5 reste respecté :
# install.sh au BUILD, `transcria.deploy.entrypoint` au RUNTIME (l'entrypoint ≠ install.sh).
#
# DEUX PILES TORCH ISOLÉES (conflit d'ABI vLLM ↔ torch projet) :
#   - /app/venv      : venv PROJET créé par install.sh (torch cu130 + pyannote + torchcodec +
#                      inference_service). `--cuda cu130` force l'index CUDA même SANS GPU au
#                      build (sinon install.sh choisirait le torch CPU).
#   - /opt/vllm-venv : venv vLLM isolé (sa propre pile torch/CUDA), ajouté par-dessus car
#                      install.sh ne gère pas vLLM. Utilisé via VLLM_BIN/STT_BIN.
# Base CUDA **devel** : nvcc requis au runtime par le JIT de vLLM (FlashInfer/Marlin).
#
# Le service tourne en **root** (fidèle à la prod, cf. transcria.service User=root) → pas
# d'utilisateur applicatif dédié. config.yaml/.env fournis au RUNTIME (volume), jamais bakés.
#
# ⚠ Alignement driver/CUDA (opérateur) : CUDA_IMAGE dont la version est supportée par vLLM
#   0.23 ET le driver NVIDIA de l'hôte (qui doit couvrir aussi cu130 du venv projet). GPU
#   exposé via CDI ; le test ouvre les **8 GPU** (`nvidia.com/gpu=all`) — le code d'autonomie
#   VRAM place arbitrage (TP=4) + STT/diar sur les cartes (c'est l'objet du test).
#
# Build (lourd) :
#   docker build -f Dockerfile.resource-node -t transcria-resource-node:latest .

ARG CUDA_IMAGE=nvidia/cuda:12.8.1-devel-ubuntu24.04
ARG TORCH_CUDA_TAG=cu130
ARG VLLM_VERSION=0.23.0


# ── Étage stt-runtimes-builder : runtimes STT servis ÉPINGLÉS (0.3.6) ────────────────────────
# Source de vérité des SHA : transcria/installer/{audiocpp,parakeetcpp}_phase.py
# (*_PINNED_COMMIT) — garder synchronisés. Arch CUDA en dur ici (image multi-cibles,
# « native » n'a pas de sens sans GPU au build) : mêmes cibles que llama.cpp.
# Binaires SEULS copiés dans l'étage final (/opt/runtimes) — modèles par VOLUME
# (Qwen3-ASR-1.7B-hf = snapshot HF pur : `hf download` suffit, pas besoin du venv
# outils d'audio.cpp en conteneur ; pointer STT_MODEL sur le chemin monté).
FROM ${CUDA_IMAGE} AS stt-runtimes-builder
ARG AUDIOCPP_REF=3982dfb29ff0b37a26b799045f85732b20a0bdef
ARG PARAKEETCPP_REF=e8acc6172a94e20a952cf1843decace5d771a94b
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        git cmake build-essential ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN git clone https://github.com/0xShug0/audio.cpp /tmp/audiocpp \
    && git -C /tmp/audiocpp checkout "${AUDIOCPP_REF}" \
    && cmake -S /tmp/audiocpp -B /tmp/audiocpp/build \
        -DCMAKE_BUILD_TYPE=Release -DGGML_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES="75;80;86;89;90" \
    && cmake --build /tmp/audiocpp/build -j "$(nproc)" --target audiocpp_server \
    && mkdir -p /opt/runtimes/audiocpp/bin \
    && cp /tmp/audiocpp/build/bin/audiocpp_server /opt/runtimes/audiocpp/bin/ \
    && echo "${AUDIOCPP_REF}" > /opt/runtimes/audiocpp/COMMIT \
    && rm -rf /tmp/audiocpp
# Stubs driver CUDA : l'exécutable lie libcuda.so.1 (symboles VMM cuMem* de ggml) absent
# d'une image devel sans GPU — on lie contre le stub, le vrai driver est injecté au runtime.
RUN ln -s /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/stubs/libcuda.so.1 \
    && export LD_LIBRARY_PATH=/usr/local/cuda/lib64/stubs \
    && git clone --recursive https://github.com/mudler/parakeet.cpp /tmp/parakeetcpp \
    && git -C /tmp/parakeetcpp checkout "${PARAKEETCPP_REF}" \
    && git -C /tmp/parakeetcpp submodule update --init --recursive \
    && cmake -S /tmp/parakeetcpp -B /tmp/parakeetcpp/build \
        -DCMAKE_BUILD_TYPE=Release -DPARAKEET_GGML_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES="75;80;86;89;90" \
        -DCMAKE_EXE_LINKER_FLAGS='-Wl,-rpath,$ORIGIN/../lib' \
        -DCMAKE_SHARED_LINKER_FLAGS='-Wl,-rpath,$ORIGIN' \
    && cmake --build /tmp/parakeetcpp/build -j "$(nproc)" \
    && mkdir -p /opt/runtimes/parakeetcpp/bin /opt/runtimes/parakeetcpp/lib \
    && cp /tmp/parakeetcpp/build/examples/server/parakeet-server /opt/runtimes/parakeetcpp/bin/ \
    && find /tmp/parakeetcpp/build -name 'libggml*.so*' -exec cp -P {} /opt/runtimes/parakeetcpp/lib/ \; \
    && echo "${PARAKEETCPP_REF}" > /opt/runtimes/parakeetcpp/COMMIT \
    && rm -rf /tmp/parakeetcpp

FROM ${CUDA_IMAGE}
ARG TORCH_CUDA_TAG
ARG VLLM_VERSION
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    TRANSCRIA_CONFIG=/app/config.yaml \
    CUDA_HOME=/usr/local/cuda

# Prérequis système d'install.sh (cf. transcria/install_prerequisites.py) : python3.12+venv,
# ffmpeg (+ libav* pour torchcodec), iproute2 (ss : vérifs de port des lanceurs), build tools,
# git/curl/sudo (détection llama, installateur opencode — non utilisé ici mais inoffensif).
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 python3.12-venv python3.12-dev \
        build-essential libpq-dev \
        ffmpeg iproute2 procps lsof git curl sudo ca-certificates \
        ninja-build \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.12 /usr/local/bin/python3
# ninja-build : requis par le JIT torch.compile/Inductor de vLLM au RUNTIME (compilation
# des CUDA graphs). Sans lui, le worker vLLM meurt (« No such file or directory: 'ninja' »)
# et le serveur d'arbitrage entre en crash-loop (cf. PLAN_TEST_SPLIT_VLLM.md, finding F6).

WORKDIR /app
COPY . /app
COPY --from=stt-runtimes-builder /opt/runtimes /opt/runtimes

# ── Install « utilisateur » du nœud de ressources (teste install.sh) ────────────
#   --no-postgres : le nœud n'a PAS de base applicative (resource-node) ;
#   --no-service  : pas de systemd en conteneur ; --skip-doctor : doctor exige GPU/réseau,
#                   absents au build (le test runtime/Phase 5 fait tourner doctor) ;
#   --cuda cu130  : force l'index torch CUDA sans GPU au build.
RUN ./install.sh --profile resource-node --inference-service \
        --non-interactive --no-service --no-postgres --skip-doctor \
        --cuda "${TORCH_CUDA_TAG}"

# ── venv vLLM isolé (STT Cohere + arbitrage) ────────────────────────────────────
RUN python3.12 -m venv /opt/vllm-venv \
    && /opt/vllm-venv/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/vllm-venv/bin/pip install --no-cache-dir "vllm==${VLLM_VERSION}" librosa soundfile

# PATH = venv PROJET (gunicorn inference_service, diarisation). Le venv vLLM N'EST PAS sur
# le PATH : les lanceurs l'atteignent via VLLM_BIN/STT_BIN (hérités par le superviseur STT).
ENV PATH="/app/venv/bin:$PATH" \
    VLLM_BIN=/opt/vllm-venv/bin/vllm \
    STT_BIN=/opt/vllm-venv/bin/vllm \
    TRANSCRIA_ROLE=resource-node \
    TRANSCRIA_RUNTIMES_DIR=/opt/runtimes

# Flask :8002 (diar/voice/superviseur). Le STT vLLM (:8003) est lancé À LA DEMANDE par
# /engines/ensure (resource_node.engines). L'arbitrage vLLM (:8080) est un service séparé.
ENTRYPOINT ["/app/venv/bin/python", "-m", "transcria.deploy.entrypoint"]
