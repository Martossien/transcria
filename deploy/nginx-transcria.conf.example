#     listen 443 ssl http2;
#     server_name transcria.example.com;
#     ssl_certificate     /etc/letsencrypt/live/transcria.example.com/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/transcria.example.com/privkey.pem;
#     client_max_body_size 1024m;
#     # … mêmes blocs location que ci-dessus …
