# Build context minimal : ni venv, ni artefacts locaux, ni secrets.
.git
.github
venv
.venv
__pycache__
*.pyc
*.pyo
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
coverage.xml
htmlcov

# Artefacts d'exécution / données locales (montés en volumes, jamais dans l'image)
jobs
models
instance
backups
logs
*.db
*.sqlite

# Secrets / configuration locale (fournis au runtime par volume ou variables)
.env
.env.*
# … MAIS garder le template versionné `.env.example` : install.sh (exécuté au build des
# images worker/resource-node) s'en sert pour générer `.env`. L'exclure faisait échouer
# le build (`FileNotFoundError: .env.example`). C'est un template sans secret.
!.env.example
config.yaml
scripts/generated

# Tests et docs (inutiles au runtime)
tests
docs
*.md

# Licences des modèles embarqués (image :bundled) : à GARDER dans le contexte malgré `*.md`
# ci-dessus (NOTICE.md) — obligation d'attribution (NVIDIA Open Model License notamment).
!licenses
!licenses/**
