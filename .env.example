# TranscrIA — Variables d'environnement (secrets)
# Copiez ce fichier en .env et remplissez les valeurs.
# Ne commitez jamais .env dans le dépôt.

# Clé secrète Flask (utilisée pour les sessions)
# Générer: python3 -c "import secrets; print(secrets.token_hex(32))"
TRANSCRIA_SECRET=change-me-to-a-random-secret

# Chemin vers le fichier de configuration YAML
# TRANSCRIA_CONFIG=config.yaml

# Rôle du process (Phase B / montée en charge) : all (défaut) | web | scheduler.
# Prioritaire sur runtime.role de config.yaml. En distribué : un seul process
# 'scheduler' + N process 'web' (gunicorn). Laisser absent = all (tout-en-un).
# TRANSCRIA_ROLE=all

# DSN de la base de données (prioritaire sur storage.database_url de config.yaml).
# Garde le mot de passe hors de la config versionnée. PostgreSQL recommandé en prod.
# TRANSCRIA_DATABASE_URL=postgresql+psycopg://transcria:CHANGE-ME@127.0.0.1:5432/transcria

# Authentification administrateur initial
# (utilisé uniquement à la première création de la base)
TRANSCRIA_ADMIN_PASSWORD=CHANGE-ME

# Token HuggingFace (nécessaire pour télécharger pyannote et certains modèles)
# https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Binaire opencode (si différent du PATH)
# TRANSCRIA_OPENCODE_BIN=/chemin/vers/opencode

# Port du serveur Flask (optionnel, prioritaire sur config.yaml)
# TRANSCRIA_PORT=7870

# Hôte d'écoute du serveur (optionnel)
# TRANSCRIA_HOST=0.0.0.0

# Mode debug (optionnel, prioritaire sur config.yaml)
# TRANSCRIA_DEBUG=false

# Logs du serveur (utilisé par start.sh)
# LOG_FILE=/var/log/transcrIA.log

# PID file (utilisé par start.sh)
# PID_FILE=/run/transcrIA.pid
