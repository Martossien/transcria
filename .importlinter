# Contrats d'architecture (import-linter, exécuté en CI — cf. docs/REFACTORING_QUALITE.md).
#
# DOCTRINE DU CLIQUET : ce fichier ne porte QUE des contrats VRAIS au moment où ils sont
# ajoutés — jamais d'aspiration. Chaque vague du plan ajoute le contrat qu'elle vient de
# rendre vrai (avec sa date). Les violations CONNUES restantes sont listées dans le plan
# (§3.4/3.6 : vram_manager→queue, package_builder/analyzer/job_facts→orchestration,
# jobs/models+timing_store→workflow, web.i18n importé par context/voice/queue → vague A1).

[importlinter]
root_packages =
    transcria
    inference_service
include_external_packages = True
# Les imports sous `if TYPE_CHECKING:` ne sont pas des dépendances d'exécution
# (B1 lot 3 : l'app Flask injectée dans scheduler/job_executor n'est qu'une annotation).
exclude_type_checking_imports = True

# A0 (2026-07-13), élargi en B1 lot 3 (2026-07-15) — l'orchestration ne connaît pas
# Flask : phases, scheduler et exécuteur doivent rester exécutables hors serveur web
# (étoile polaire du plan, §5.2 ; état final §8.2). L'app Flask est INJECTÉE dans
# scheduler/job_executor (annotations sous TYPE_CHECKING, app_context() duck-typé).
[importlinter:contract:orchestration-sans-flask]
name = L'orchestration (workflow, queue, services) n'importe pas Flask
type = forbidden
source_modules =
    transcria.workflow
    transcria.queue
    transcria.services
forbidden_modules =
    flask
ignore_imports =
    # logging_setup importe flask en DIFFÉRÉ GARDÉ (try/except ImportError — fonctionne
    # sans Flask) pour enrichir les logs du correlation_id en contexte requête :
    # exception §8.3 du plan, pas une dépendance.
    transcria.logging_setup -> flask
    # queue/routes.py est un blueprint web qui vit dans queue/ — son déménagement vers
    # web/ relève de la piste A (routes), pas de B1 ; ces exceptions meurent avec lui.
    # (Premiers sauts seulement : les modules cibles restent couverts pour le reste
    # de l'orchestration.)
    transcria.queue.routes -> flask
    transcria.queue.routes -> transcria.audit.decorator
    transcria.queue.routes -> transcria.auth.permissions
    transcria.queue.routes -> transcria.i18n

# A0 (2026-07-13), élargi en A1 (2026-07-13) — l'interface web n'est pas une dépendance :
# PERSONNE ne l'importe (l'inversion web.i18n de context/voice/queue est morte en A1,
# la résolution de locale vit dans transcria.i18n).
[importlinter:contract:web-pas-une-dependance]
name = Les domaines et le noyau n'importent pas transcria.web
type = forbidden
source_modules =
    transcria.context
    transcria.voice
    transcria.queue
    transcria.i18n
    transcria.stt
    transcria.audio
    transcria.gpu
    transcria.exports
    transcria.quality
    transcria.notifications
    transcria.jobs
    transcria.auth
    transcria.config
    transcria.audit
    transcria.workflow
    transcria.services
forbidden_modules =
    transcria.web

# A2 (2026-07-14) — les modules de routes web ne s'importent JAMAIS entre eux : tout
# helper partagé vit dans un module dédié (job_access, request_helpers, lexicon_views,
# refine_shared) ou dans routes.py (câblage transverse : hooks/filtres).
[importlinter:contract:routes-independantes]
name = Les modules de routes web sont indépendants entre eux
type = independence
modules =
    transcria.web.pages_routes
    transcria.web.wizard_api
    transcria.web.lexicon_api
    transcria.web.processing_api
    transcria.web.downloads_api
    transcria.web.refine_api
    transcria.web.admin_routes
    transcria.web.health_routes
    transcria.web.editor_routes

# A0 (2026-07-13) — pureté (partielle) du noyau : auth/config/audit n'importent pas
# l'orchestration. (jobs/ a deux imports de constantes workflow connus — hors contrat
# tant qu'ils vivent, cf. plan.)
[importlinter:contract:noyau-sans-orchestration]
name = auth/config/audit n'importent pas l'orchestration
type = forbidden
source_modules =
    transcria.auth
    transcria.config
    transcria.audit
forbidden_modules =
    transcria.workflow
    transcria.queue
    transcria.services
